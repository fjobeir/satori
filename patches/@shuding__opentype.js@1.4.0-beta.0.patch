+                    for (let n = 0; n < inputLookups.length; n++) {
+                        const glyphIndex = contextParams.get(n);
+                        const substitution = lookup(glyphIndex);
+                        if (substitution) substitutions.push(substitution);
+                    }
+                }
+            }
+        }
+    }
+    return substitutions;
+}
