+function contextSubstitutionFormat3(contextParams, subtable) {
+    if (contextParams.context.length < subtable.coverages.length) {
+        return [];
+    }
+    let inputLookups = lookupCoverageList(
+        subtable.coverages, contextParams
+    );
+    if (inputLookups === -1) {
+        return [];
